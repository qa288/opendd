TENANT_ID=user001
TENANT_DOMAIN=user001.ope.tyos.cc
TENANT_DATA_DIR=/data/openclaw-tenants/user001/openclaw
WEB_PORT=18791
OAUTH_PORT=31891

OPENDD_IMAGE=ghcr.io/qa288/opendd:2026.5.7
OPENDD_RENDER_CONFIG=missing
OPENDD_SEND_AUTH_CARD_ON_START=0
OPENDD_PAIRING_AUTH_WATCHER=1
FEISHU_AUTH_CARD_MODE=guided

OPENCLAW_GATEWAY_TOKEN=replace-with-random-token
OPENCLAW_MODEL_PROVIDER=bailian-coding-plan
OPENCLAW_MODEL_ID=qwen3.6-plus
OPENCLAW_MODEL_API=openai-completions
OPENCLAW_MODEL_BASE_URL=https://coding.dashscope.aliyuncs.com/v1
OPENCLAW_MODEL_API_KEY=replace-with-model-api-key

DASHSCOPE_API_KEY=replace-with-dashscope-api-key
OPENCLAW_EMBEDDING_PROVIDER=openai
OPENCLAW_EMBEDDING_API_KEY=
OPENCLAW_EMBEDDING_MODEL=text-embedding-v4
OPENCLAW_EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

FEISHU_ENABLED=true
FEISHU_DOMAIN=feishu
FEISHU_APP_ID=cli_xxx
FEISHU_APP_SECRET=replace-with-feishu-app-secret
FEISHU_OWNER_OPEN_ID=
FEISHU_AUTH_TARGET_MODE=first_sender
FEISHU_AUTH_BIND_FIRST_USER=1
FEISHU_DM_POLICY=pairing
FEISHU_GROUP_POLICY=open
FEISHU_GROUP_OWNER_ONLY=1
